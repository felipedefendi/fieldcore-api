# Copie para .env e ajuste conforme necessario.
# Fluxo recomendado em dev: `docker compose up postgres adminer -d` e rode a API
# localmente com `npm run start:dev` (DATABASE_URL abaixo aponta pro Postgres exposto em localhost).

DATABASE_URL=postgresql://fieldcore:fieldcore@localhost:5432/fieldcore

JWT_ACCESS_SECRET=troque-por-um-segredo-forte-de-acesso
JWT_ACCESS_EXPIRES_IN=15m

JWT_REFRESH_SECRET=troque-por-um-segredo-forte-de-refresh
JWT_REFRESH_EXPIRES_IN=7d

PORT=3000
CORS_ORIGIN=http://localhost:3000
